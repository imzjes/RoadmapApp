// ============================================================
// Secrets.example.xcconfig — COMMITTED TEMPLATE
// ============================================================
// Copy this file to Config/Secrets.xcconfig and set the URL.
// Secrets.xcconfig is gitignored and must never be committed.
//
// Deploy the Cloudflare Worker from roadmap-worker/ first, then
// paste the deployed URL here (no trailing slash).
// Note: the SLASH indirection is needed because `//` is a
// comment token in xcconfig files.
// ============================================================

SLASH = /
ROADMAP_WORKER_URL = https:$(SLASH)$(SLASH)YOUR_WORKER_URL_HERE
